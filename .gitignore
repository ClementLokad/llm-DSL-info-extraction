# =============================================================================
# LLM DSL INFORMATION EXTRACTION - PROJECT SPECIFIC .GITIGNORE
# =============================================================================

# =============================================================================
# SENSITIVE DATA & API KEYS
# =============================================================================
.env

# =============================================================================
# PYTHON RUNTIME & CACHE FILES
# =============================================================================
# Virtual environment (project uses env/)
env/

# Python bytecode
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class

# Pytest cache
.pytest_cache/

# =============================================================================
# GENERATED DATA & INDEXES (can be rebuilt)
# =============================================================================
# FAISS index files (generated by build_index.py)
data/faiss_index/
*.pkl
*.pickle

# Query sessions (generated by main.py)
data/sessions/

# =============================================================================
# PROJECT SPECIFIC EXCLUSIONS
# =============================================================================
# Source data directories (may contain proprietary DSL files)
# NOTE: These files are searchable in VS Code (see .vscode/settings.json)
#       but ignored by Git to avoid committing proprietary code
env_scripts/

# Test outputs
test_results.json

# To ignore local models
saved_models/


# =============================================================================
# DEVELOPMENT ENVIRONMENT
# =============================================================================
# IDE files (only common ones)
# .vscode/ is now tracked to share search settings with team
.idea/
.vscode/

# Logs
*.log