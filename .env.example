# ================================================
# EMBEDDING MODELS API KEYS
# ================================================

# Google AI Studio API Key (for Gemini embeddings)
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI API Key (for OpenAI embeddings)
OPENAI_API_KEY=your-openai-api-key-here

# ================================================
# LLM AGENTS API KEYS (for future query phase)
# ================================================

# Mistral AI API Key
MISTRAL_API_KEY=your-mistral-api-key-here

# ================================================
# PREPROCESSING DEFAULTS (optional)
# ================================================

# Default embedding model to use (mock, gemini, openai, huggingface)
DEFAULT_EMBEDDING_MODEL=mock

# Default chunk size for text processing
DEFAULT_CHUNK_SIZE=512

# Default overlap between chunks
DEFAULT_CHUNK_OVERLAP=50